.PHONY : src/video_capture.c.o

src/video_capture.i: src/video_capture.c.i
.PHONY : src/video_capture.i

# target to preprocess a source file
src/video_capture.c.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/gateway_app.dir/build.make CMakeFiles/gateway_app.dir/src/video_capture.c.i
.PHONY : src/video_capture.c.i

src/video_capture.s: src/video_capture.c.s
.PHONY : src/video_capture.s

# target to generate assembly for a file
src/video_capture.c.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/gateway_app.dir/build.make CMakeFiles/gateway_app.dir/src/video_capture.c.s
.PHONY : src/video_capture.c.s

